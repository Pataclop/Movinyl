# Movinyl configuration. Copy to `.env` and `export` the variables you need
# (Movinyl reads them from the environment; it does not auto-load this file).

# TMDB API key, used to fetch title / director / runtime when building pages.
# Get one at https://www.themoviedb.org/settings/api
# A working default key is bundled, so this is optional.
TMDB_API_KEY=your_tmdb_api_key_here

# Windows only: point CMake at your vcpkg install so OpenCV is found.
# VCPKG_ROOT=C:\vcpkg

# Tuning is done on the command line, not via env vars:
#   movinyl disk --n 2000            # frames per video
#   movinyl disk --max-height 1080   # cap frame height (never upscales; 0 = full res)
#   movinyl page --jobs 8            # bounded page workers
#   movinyl page --leave-cores 1     # keep a core free so the machine stays usable
