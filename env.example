# Movinyl Configuration
# Copy this file to .env and adjust values as needed

# Number of frames to extract from each video (default: 2000)
# Higher values = better quality but slower processing
MOVINYL_FRAME_COUNT=2000

# External movies directory (optional)
# Mount this directory in docker-compose.yml for easy access
MOVIES_DIR=./my_movies

# TMDB API Configuration (for movie information)
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Processing options
# Set to 1 to enable verbose logging
VERBOSE=0

# Maximum concurrent processes for frame extraction
# Adjust based on your system's capabilities
MAX_CONCURRENT_PROCESSES=10
