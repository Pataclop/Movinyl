#!/bin/bash

# Movinyl Batch Processing Script
# Compatible with containerized environments

set -e  # Exit on any error

size=${MOVINYL_FRAME_COUNT:-2000}

echo "Starting batch processing with $size frames per video..."

# Check if we're in the right directory
if [ ! -d "PROCESSING_ZONE" ]; then
    echo "ERROR: PROCESSING_ZONE directory not found!"
    echo "Please run this script from the Movinyl root directory."
    exit 1
fi

cd PROCESSING_ZONE

# Rename files to remove problematic characters (only if rename command exists)
if command -v rename &> /dev/null; then
    echo "Renaming files to remove special characters..."
    rename 's/[()]//g' * 2>/dev/null || true
    rename 's/[ :!]/_/g' * 2>/dev/null || true
else
    echo "rename command not available, skipping filename cleanup"
fi
# Function to check if file is a video
is_video_file() {
    local file="$1"
    local ext="${file##*.}"
    case "$ext" in
        mp4|mkv|avi|mov|flv|wmv|webm|mpg|mpeg|3gp|ogv|mts|m2ts|ts)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# Process each video file
for file in *; do
    # Skip if not a file or not a video
    if [ ! -f "$file" ] || ! is_video_file "$file"; then
        continue
    fi

    echo "Processing video: $file"

    # Clean up any existing directory for this video
    video_dir="${file%.*}"
    if [ -d "$video_dir" ]; then
        echo "Removing existing directory: $video_dir"
        rm -rf "$video_dir"
    fi

    mkdir -p "$video_dir/images"

    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create directory $video_dir"
        continue
    fi

    # Get video duration
    len=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$file" 2>/dev/null)

    if [ -z "$len" ] || [ "$len" = "N/A" ]; then
        echo "ERROR: Could not determine duration for $file"
        continue
    fi

    echo "Video duration: $len seconds"
    echo "Extracting $size frames from $file"

    # Cleanup function for graceful interruption
    cleanup() {
        echo "Interruption detected, cleaning up..."
        # Kill any background ffmpeg processes
        pkill -f "ffmpeg.*$file" || true
        # Clean up partial extractions
        if [ -d "$video_dir" ]; then
            rm -rf "$video_dir"
        fi
        exit 1
    }

    # Set up signal handlers
    trap cleanup SIGINT SIGTERM

    # Calculate frame rate (r) using awk instead of bc for better portability
    r=$(awk "BEGIN { printf \"%.10f\", $len / ($size + 5) }")

    # Extract frames in parallel
    echo "Starting frame extraction..."
    for ((i=0; i<=$((size + 3)); i++)); do
        # Calculate timestamp using awk
        stamp=$(awk "BEGIN { printf \"%.10f\", $i * $r }")

        # Extract frame with ffmpeg
        ffmpeg -y -nostdin -threads 1 -hide_banner -loglevel panic \
            -accurate_seek -ss "$stamp" -i "$file" \
            -vf "cropdetect=24:16:0" -q:v 1 -frames:v 1 \
            "$video_dir/images/$i.jpg" &

        # Limit concurrent processes to avoid overwhelming the system
        if (( (i + 1) % 10 == 0 )); then
            wait  # Wait for some processes to finish
        fi
    done

    # Wait for all background processes to complete
    wait

    # Count processed frames
    number_of_processed_frames=$(ls "$video_dir/images" 2>/dev/null | wc -l)
    echo "Initial frame count: $number_of_processed_frames"

    # Final frame count check
    final_frame_count=$(ls "$video_dir/images" 2>/dev/null | wc -l)
    echo "Final frame count: $final_frame_count"

    if (( final_frame_count < size )); then
        echo "WARNING: Only extracted $final_frame_count frames out of $size expected"
    fi

    # Fill in any missing frames by copying from previous frames
    echo "Checking for missing frames..."
    missing_count=0
    for i in $(seq 0 $((size + 1))); do
        frame_file="$video_dir/images/${i}.jpg"
        if [ ! -f "$frame_file" ]; then
            prev=$((i - 1))
            if [ $prev -ge 0 ] && [ -f "$video_dir/images/${prev}.jpg" ]; then
                cp "$video_dir/images/${prev}.jpg" "$frame_file"
                ((missing_count++))
            else
                echo "WARNING: Cannot create missing frame ${i}.jpg - no previous frame available"
            fi
        fi
    done

    if (( missing_count > 0 )); then
        echo "Filled in $missing_count missing frames"
    fi

    # Generate disk using the C++ program
    echo "Generating disk visualization..."
    if [ ! -f "../disk" ]; then
        echo "ERROR: disk executable not found in parent directory"
        continue
    fi

    cp "../disk" "$video_dir/"

    # Change to video directory and run disk generation
    (
        cd "$video_dir" || exit 1
        frame_count=$(ls -l images | grep -c '^-')
        echo "Running disk generation with $frame_count frames..."

        if ./disk "$size"; then
            echo "Disk generation completed for $file"
        else
            echo "ERROR: Disk generation failed for $file"
            exit 1
        fi
    )

    # Return to processing directory
    cd ..
fi
done

# Organize generated disk images
echo "Organizing generated disk images..."
generated_count=0
for dir in *; do
    if [ -d "$dir" ] && [ -f "$dir/save.png" ]; then
        echo "Moving disk image: $dir.png"
        mv "$dir/save.png" "$dir.png"
        mv "$dir.png" ..
        ((generated_count++))
    fi
done

echo "Batch processing completed!"
echo "Generated $generated_count disk images"
echo ""
echo "Next steps:"
echo "1. Move the generated PNG files to the PAGE_ZONE directory"
echo "2. Run the page generation script: ../2_MAKE_PAGE"


