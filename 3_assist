#!/bin/bash

# Movinyl Page Assist Script
# Processes individual PNG files to create movie information pages

set -e  # Exit on any error

file="$1"

if [ -z "$file" ]; then
    echo "ERROR: No file specified"
    echo "Usage: $0 <filename.png>"
    exit 1
fi

if [ ! -f "$file" ]; then
    echo "ERROR: File '$file' not found"
    exit 1
fi

echo "Processing page for: $file"

# Create temporary working directory
temp_dir="${file%.*}_temp"
if [ -d "$temp_dir" ]; then
    rm -rf "$temp_dir"
fi
mkdir "$temp_dir"
cd "$temp_dir"

# Copy required files
mv "../$file" .
cp ../../page .
cp ../../generate_infos.py .
cp ../../*.ttf .

# Check if required tools are available
if ! command -v convert &> /dev/null; then
    echo "ERROR: ImageMagick 'convert' command not found"
    exit 1
fi

if ! command -v extcolors &> /dev/null; then
    echo "ERROR: extcolors command not found"
    exit 1
fi

# Extract color palette from disk image
echo "Extracting color palette..."
if ! convert -crop 150x3925+1950+50 "$file" crop.png 2>/dev/null; then
    echo "WARNING: Failed to extract color palette, using default colors"
    # Create a default colors.txt file
    echo "255,255,255,255
128,128,128,255
64,64,64,255
32,32,32,255
16,16,16,255" > colors.txt
else
    # Extract colors using extcolors
    if ! extcolors crop.png -t 12 -l 8 > colors.txt 2>/dev/null; then
        echo "WARNING: extcolors failed, using default colors"
        echo "255,255,255,255
128,128,128,255
64,64,64,255
32,32,32,255
16,16,16,255" > colors.txt
    fi
    rm -f crop.png
fi

# Generate movie information
echo "Generating movie information..."
if ! python3 generate_infos.py "${file%.*}"; then
    echo "ERROR: Failed to generate movie information"
    exit 1
fi

# Move disk back to parent directory temporarily for processing
cp "$file" ..

# Generate the page
echo "Generating page layout..."
if ! ./page "${file%.*}"; then
    echo "ERROR: Page generation failed"
    exit 1
fi

# Clean up temporary files
rm -f année.png durée.png palette.png réalisateur.png titre.png *.ttf *.py page "$file"

# Move generated pages back to parent directory
mv *.png ..

# Return to parent directory and clean up
cd ..
rm -rf "$temp_dir"

echo "Page generation completed for: $file"
